{
    "functions": {
        "backend/main.py": {
            "runtime": "vercel-python@0.1.1"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "/backend/main.py"
        }
    ]
}